---
import SectionHeader from './SectionHeader.astro';
---

<section id="private">
  <div class="inner">
    <SectionHeader num="02" title="Private" />
    <div class="private-body">
      <div class="private-text">
        <p>
          This section is reserved for invited readers. It contains extended research notes, unpublished datasets, and
          draft articles not available in the public feed.
        </p>
        <div class="private-access">
          <a class="private-btn" href="/private">Enter Private Space →</a>
        </div>
      </div>
      <div class="lock-visual">
        <div class="lock-dots"></div>
        <div class="lock-label">02</div>
        <div class="lock-icon-wrap">
          <div class="lock-icon"></div>
          <div class="lock-tag">Private Access</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #private {
    background: var(--bg-muted);
    border-top: 1px solid var(--border-default);
    border-bottom: 1px solid var(--border-default);
    padding: 0;
  }
  #private .inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 80px 32px;
  }
  .private-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .private-text p {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 300;
    line-height: 1.75;
    color: var(--fg-secondary);
    margin-bottom: 32px;
  }
  .private-access {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 14px;
  }
  .private-btn {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    background: #fff;
    color: #000;
    border: none;
    padding: 13px 28px;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .private-btn:hover {
    opacity: 0.82;
  }
  .lock-visual {
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border-default);
    aspect-ratio: 1;
    max-width: 300px;
    position: relative;
    overflow: hidden;
  }
  .lock-dots {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(255, 255, 255, 0.1) 1px, transparent 1px);
    background-size: 20px 20px;
  }
  .lock-label {
    font-family: var(--font-display);
    font-size: 7rem;
    color: rgba(255, 255, 255, 0.05);
    letter-spacing: 0.04em;
    position: relative;
  }
  .lock-icon-wrap {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }
  .lock-icon {
    width: 30px;
    height: 34px;
    border: 2px solid rgba(255, 255, 255, 0.35);
    position: relative;
  }
  .lock-icon::before {
    content: '';
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    width: 17px;
    height: 13px;
    border: 2px solid rgba(255, 255, 255, 0.35);
    border-bottom: none;
    border-radius: 9px 9px 0 0;
  }
  .lock-tag {
    font-family: var(--font-body);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.25);
  }
</style>
