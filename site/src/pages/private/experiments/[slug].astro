---
export const prerender = false;

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import { getEntry, render } from 'astro:content';

const { slug } = Astro.params;
const entry = slug ? await getEntry('experiments', slug) : undefined;

if (!entry) {
  return Astro.redirect('/private/experiments');
}

const { Content } = await render(entry);
const { title, date, status, hypothesis, result, tags, updated } = entry.data;

const STATUS_LABEL: Record<typeof status, string> = {
  running: 'Running',
  done: 'Done',
  abandoned: 'Abandoned',
};

function formatDate(d: Date) {
  return d.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<BaseLayout title={`${title} — Mathlacome`}>
  <Nav active="private" />

  <div class="page-header">
    <a href="/private/experiments" class="back-link">← Lab Notebook</a>

    <div class="entry-meta">
      <span class={`status-badge is-${status}`}>{STATUS_LABEL[status]}</span>
      <span class="entry-date">Started {formatDate(date)}</span>
      {updated && <span class="entry-date">· Updated {formatDate(updated)}</span>}
    </div>

    <h1 class="page-title">{title}</h1>

    <p class="hypothesis">
      <span class="hypothesis-label">Hypothesis —</span> {hypothesis}
    </p>

    {
      status === 'running' ? (
        <div class="lead-callout is-running">
          <span class="lead-label">Still running</span>
          <p class="lead-text">No result yet — check back as this one develops.</p>
        </div>
      ) : (
        result && (
          <div class="lead-callout">
            <span class="lead-label">Result</span>
            <p class="lead-text">{result}</p>
          </div>
        )
      )
    }

    {
      tags.length > 0 && (
        <div class="entry-tags">
          {tags.map((tag) => (
            <span class="entry-tag">{tag}</span>
          ))}
        </div>
      )
    }
  </div>

  <article class="experiment-body">
    <Content />
  </article>

  <Footer />
</BaseLayout>

<style>
  .page-header {
    padding: 96px 32px 48px;
    max-width: 720px;
    margin: 0 auto;
    width: 100%;
    border-bottom: 1px solid var(--border-default);
  }
  .back-link {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fg-secondary);
    text-decoration: none;
    margin-bottom: 28px;
    transition: color 0.12s;
  }
  .back-link:hover {
    color: var(--fg-primary);
  }
  .entry-meta {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 20px;
  }
  .entry-date {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-tertiary);
  }
  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.25rem);
    line-height: 1;
    letter-spacing: 0.02em;
    margin-bottom: 20px;
  }
  .hypothesis {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 300;
    line-height: 1.65;
    color: var(--fg-secondary);
    margin-bottom: 24px;
  }
  .hypothesis-label {
    font-weight: 600;
    color: var(--fg-primary);
  }

  .lead-callout {
    border-top: 2px solid var(--fg-primary);
    padding-top: 16px;
    margin-bottom: 24px;
  }
  .lead-label {
    display: block;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--fg-secondary);
    margin-bottom: 8px;
  }
  .lead-text {
    font-family: var(--font-display);
    font-size: 1.4rem;
    line-height: 1.3;
    letter-spacing: 0.01em;
    color: var(--fg-primary);
  }
  .lead-callout.is-running .lead-text {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 14px;
    color: var(--fg-secondary);
  }

  .entry-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .entry-tag {
    font-family: var(--font-body);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-tertiary);
  }
  .entry-tag::before {
    content: '#';
  }

  .status-badge {
    font-family: var(--font-body);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 3px 8px;
    border: 1px solid var(--border-default);
    white-space: nowrap;
  }
  .status-badge.is-done {
    background: #fff;
    color: #000;
    border-color: #fff;
  }
  .status-badge.is-running {
    color: var(--fg-primary);
    border-color: var(--fg-primary);
  }
  .status-badge.is-abandoned {
    color: var(--fg-tertiary);
    border-color: var(--border-default);
  }

  .experiment-body {
    max-width: 720px;
    margin: 0 auto;
    width: 100%;
    padding: 48px 32px 96px;
  }
  .experiment-body :global(h2) {
    font-family: var(--font-display);
    font-size: 1.5rem;
    letter-spacing: 0.02em;
    color: var(--fg-primary);
    margin-top: 40px;
    margin-bottom: 16px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border-default);
  }
  .experiment-body :global(h2:first-child) {
    margin-top: 0;
  }
  .experiment-body :global(p) {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 300;
    line-height: 1.75;
    color: var(--fg-secondary);
    margin-bottom: 16px;
  }
  .experiment-body :global(svg) {
    display: block;
    margin: 20px 0;
  }
  .experiment-body :global(ul),
  .experiment-body :global(ol) {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 300;
    line-height: 1.75;
    color: var(--fg-secondary);
    margin-bottom: 16px;
    padding-left: 20px;
  }
  .experiment-body :global(img) {
    max-width: 100%;
    border: 1px solid var(--border-default);
    margin: 20px 0;
  }
  .experiment-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--bg-muted);
    padding: 2px 5px;
  }
</style>
