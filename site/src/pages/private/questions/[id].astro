---
export const prerender = false;

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import { createSupabaseServerClient } from '../../../lib/supabase';
import type { Question } from '../../../lib/questions';

const { id } = Astro.params;
const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
const {
  data: { user },
} = await supabase.auth.getUser();

const { data } = await supabase
  .from('questions')
  .select('id, body, author_email, status, answer, tags, like_count, answered_at, created_at')
  .eq('id', id)
  .single<Question>();

if (!data || data.status !== 'answered') {
  return Astro.redirect('/private/questions');
}

const question = data;

let liked = false;
if (user) {
  const { data: like } = await supabase
    .from('question_likes')
    .select('id')
    .eq('question_id', question.id)
    .eq('user_id', user.id)
    .maybeSingle();
  liked = !!like;
}

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' });
}

// Same lightweight prose parser as the "Books I Read" page: blank lines start
// new paragraphs, "## Title" renders a bold hard-caps header, "- item" / "1. item"
// render bullet lists, and single line breaks inside a paragraph are preserved
// (rendered via white-space: pre-line) so the answer keeps the shape it was typed in.
type ProseBlock =
  | { kind: 'heading'; text: string }
  | { kind: 'list'; items: string[] }
  | { kind: 'para'; text: string };

function parseProse(text: string | null): ProseBlock[] {
  const lines = (text ?? '').replace(/\r\n/g, '\n').split('\n');
  const blocks: ProseBlock[] = [];
  let para: string[] = [];
  let list: string[] = [];
  const flushPara = () => {
    if (para.length) blocks.push({ kind: 'para', text: para.join('\n') });
    para = [];
  };
  const flushList = () => {
    if (list.length) blocks.push({ kind: 'list', items: list });
    list = [];
  };
  for (const raw of lines) {
    const line = raw.trim();
    if (!line) {
      flushPara();
      flushList();
      continue;
    }
    const heading = line.match(/^#{1,6}\s+(.*)$/);
    const bullet = line.match(/^(?:[-*•]|\d+[.)])\s+(.*)$/);
    if (heading) {
      flushPara();
      flushList();
      blocks.push({ kind: 'heading', text: heading[1] });
    } else if (bullet) {
      flushPara();
      list.push(bullet[1]);
    } else {
      flushList();
      para.push(line);
    }
  }
  flushPara();
  flushList();
  return blocks;
}

const answerBlocks = parseProse(question.answer);
---

<BaseLayout title="Your Questions → My Answers — Mathlacome">
  <Nav active="private" />

  <div class="page-header">
    <a href="/private/questions" class="back-link">← Your Questions → My Answers</a>

    {
      question.tags.length > 0 && (
        <div class="entry-tags">
          {question.tags.map((tag) => (
            <span class="entry-tag">{tag}</span>
          ))}
        </div>
      )
    }

    <h1 class="question-title">{question.body}</h1>

    <div class="entry-meta">
      <span>Answered {formatDate(question.answered_at ?? question.created_at)}</span>
    </div>

    <form method="POST" action="/api/questions/like" class="like-form">
      <input type="hidden" name="questionId" value={question.id} />
      <input type="hidden" name="next" value={`/private/questions/${question.id}`} />
      <button type="submit" class={`like-btn${liked ? ' is-liked' : ''}`}>
        {liked ? 'Liked' : 'Like'} · {question.like_count}
      </button>
    </form>
  </div>

  <article class="answer-body">
    <span class="answer-label">My Answer</span>
    <div class="prose">
      {
        answerBlocks.map((blk) =>
          blk.kind === 'heading' ? (
            <h3 class="prose-h">{blk.text}</h3>
          ) : blk.kind === 'list' ? (
            <ul class="prose-ul">
              {blk.items.map((it) => (
                <li class="prose-li">{it}</li>
              ))}
            </ul>
          ) : (
            <p class="prose-p">{blk.text}</p>
          ),
        )
      }
    </div>
  </article>

  <Footer />
</BaseLayout>

<style>
  .page-header {
    padding: 96px 32px 40px;
    max-width: 720px;
    margin: 0 auto;
    width: 100%;
    border-bottom: 1px solid var(--border-default);
  }
  .back-link {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fg-secondary);
    text-decoration: none;
    margin-bottom: 28px;
    transition: color 0.12s;
  }
  .back-link:hover {
    color: var(--fg-primary);
  }
  .entry-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }
  .entry-tag {
    font-family: var(--font-body);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-tertiary);
  }
  .entry-tag::before {
    content: '#';
  }
  .question-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4.5vw, 2.75rem);
    line-height: 1.1;
    letter-spacing: 0.02em;
    margin-bottom: 16px;
  }
  .entry-meta {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-tertiary);
    margin-bottom: 20px;
  }
  .like-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg-secondary);
    background: none;
    border: 1px solid var(--border-default);
    padding: 8px 14px;
    cursor: pointer;
    transition: all 0.12s;
  }
  .like-btn:hover,
  .like-btn.is-liked {
    color: #000;
    background: #fff;
    border-color: #fff;
  }

  .answer-body {
    max-width: 720px;
    margin: 0 auto;
    width: 100%;
    padding: 48px 32px 96px;
  }
  .answer-label {
    display: block;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--fg-secondary);
    margin-bottom: 16px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--border-default);
  }
  /* Same readable treatment as the "Books I Read" page: white, weightier body
     copy; bold hard-caps headers; normal-case bullets. Paragraphs use
     pre-line so single line breaks in the typed answer are preserved. */
  .prose {
    max-width: 700px;
  }
  .prose-p {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.8;
    color: var(--fg-primary);
    margin-bottom: 18px;
    white-space: pre-line;
  }
  .prose-h {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg-primary);
    margin: 32px 0 14px;
  }
  .prose > .prose-h:first-child {
    margin-top: 0;
  }
  .prose-ul {
    list-style: disc;
    padding-left: 22px;
    margin-bottom: 18px;
  }
  .prose-li {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.7;
    color: var(--fg-primary);
    margin-bottom: 12px;
    padding-left: 4px;
  }
  .prose-li::marker {
    color: var(--fg-tertiary);
  }
</style>
