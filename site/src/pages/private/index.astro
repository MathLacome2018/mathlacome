---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { isAdminEmail } from '../../lib/supabase-admin';

const user = Astro.locals.user;
const admin = isAdminEmail(user?.email);
---

<BaseLayout title="Private — Mathlacome">
  <Nav active="private" />

  <div class="page-header">
    <div class="page-label">02 / Private</div>
    <h1 class="page-title">Private<br />Space.</h1>
    <div class="page-blurb">
      <!-- Replace these three lines with your real copy -->
      <p class="blurb-line">This is a personal space — not a curated feed, not a publication.</p>
      <p class="blurb-line">Three ongoing notebooks: what I read, what I test on myself, and the questions you ask me.</p>
      <p class="blurb-line">Unfiltered, updated without schedule, written for those who asked to be here.</p>
    </div>
    <div class="account-bar">
      <span>Signed in as {user?.email}</span>
      {admin && <a href="/private/admin" class="admin-link">Admin →</a>}
      <form method="POST" action="/api/auth/logout">
        <button type="submit" class="logout-btn">Log out</button>
      </form>
    </div>
  </div>

  <div class="boxes-wrap">
    <a href="/private/books" class="box">
      <div class="box-dot-field"></div>
      <div class="box-num">01</div>
      <div class="box-icon">B</div>
      <div class="box-title">Books<br />I Read.</div>
      <div class="box-desc">
        Notes, highlights and takeaways from books I am reading or have read. Not reviews — raw annotations and the
        ideas that stuck.
      </div>
      <div class="box-cta">
        <span class="box-cta-label">Enter</span>
        <span class="box-arrow">→</span>
      </div>
    </a>

    <a href="/private/experiments" class="box">
      <div class="box-dot-field"></div>
      <div class="box-num">02</div>
      <div class="box-icon">E</div>
      <div class="box-title">Life<br />Experiments.</div>
      <div class="box-desc">
        Personal protocols, interventions and observations. Sleep, training, nutrition, cognition — what I try, what I
        track, what I conclude.
      </div>
      <div class="box-cta">
        <span class="box-cta-label">Enter</span>
        <span class="box-arrow">→</span>
      </div>
    </a>

    <a href="/private/questions" class="box">
      <div class="box-dot-field"></div>
      <div class="box-num">03</div>
      <div class="box-icon">Q</div>
      <div class="box-title">Your Questions<br />→ My Answers.</div>
      <div class="box-desc">
        Questions sent by readers, answered in full. If it's worth asking, it's worth a proper answer — not a tweet.
      </div>
      <div class="box-cta">
        <span class="box-cta-label">Enter</span>
        <span class="box-arrow">→</span>
      </div>
    </a>
  </div>

  <Footer />
</BaseLayout>

<style>
  .page-header {
    padding: 96px 32px 56px;
    max-width: 1100px;
    margin: 0 auto;
    width: 100%;
    border-bottom: 1px solid var(--border-default);
  }
  .page-label {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fg-secondary);
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .page-label::before {
    content: '';
    display: inline-block;
    width: 5px;
    height: 5px;
    background: var(--fg-primary);
  }
  .page-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 6rem);
    line-height: 0.92;
    letter-spacing: 0.02em;
    margin-bottom: 36px;
  }
  .page-blurb {
    max-width: 580px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: 40px;
  }
  .blurb-line {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 300;
    line-height: 1.7;
    color: var(--fg-secondary);
    letter-spacing: 0.02em;
  }
  .account-bar {
    display: flex;
    align-items: center;
    gap: 16px;
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--fg-secondary);
    border-top: 1px solid var(--border-default);
    padding-top: 20px;
  }
  .admin-link {
    margin-left: auto;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-primary);
    text-decoration: none;
  }
  .admin-link:hover {
    opacity: 0.7;
  }
  .logout-btn {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-secondary);
    background: none;
    border: 1px solid var(--border-default);
    padding: 6px 14px;
    cursor: pointer;
    transition: all 0.12s;
  }
  .logout-btn:hover {
    color: #000;
    background: #fff;
    border-color: #fff;
  }

  .boxes-wrap {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    max-width: 1100px;
    margin: 0 auto;
    width: 100%;
    padding: 0 32px 64px;
  }
  .box:not(:last-child) {
    border-right: 1px solid var(--border-default);
  }
  .box {
    padding: 48px 40px 40px;
    display: flex;
    flex-direction: column;
    cursor: pointer;
    transition:
      background 0.2s,
      color 0.2s;
    position: relative;
    overflow: hidden;
    border-top: 1px solid var(--border-default);
    color: inherit;
    text-decoration: none;
  }
  .box::after {
    content: '';
    position: absolute;
    inset: 0;
    background: #fff;
    transform: translateY(100%);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 0;
  }
  .box:hover::after {
    transform: translateY(0);
  }
  .box:hover {
    color: #000;
  }
  .box > * {
    position: relative;
    z-index: 1;
  }
  .box-num {
    font-family: var(--font-display);
    font-size: 0.95rem;
    letter-spacing: 0.08em;
    color: var(--fg-secondary);
    margin-bottom: auto;
    padding-bottom: 40px;
    transition: color 0.2s;
  }
  .box:hover .box-num {
    color: rgba(0, 0, 0, 0.35);
  }
  .box .box-dot-field {
    position: absolute;
    top: 0;
    right: 0;
    width: 180px;
    height: 180px;
    pointer-events: none;
  }
  .box-dot-field::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(255, 255, 255, 0.15) 1px, transparent 1px);
    background-size: 14px 14px;
    -webkit-mask-image: radial-gradient(ellipse 80% 80% at 70% 30%, black 20%, transparent 75%);
    mask-image: radial-gradient(ellipse 80% 80% at 70% 30%, black 20%, transparent 75%);
    transition: opacity 0.2s;
  }
  .box:hover .box-dot-field::before {
    opacity: 0;
  }
  .box-icon {
    font-family: var(--font-display);
    font-size: 5rem;
    line-height: 1;
    letter-spacing: 0.01em;
    color: rgba(255, 255, 255, 0.06);
    margin-bottom: 20px;
    transition: color 0.2s;
  }
  .box:hover .box-icon {
    color: rgba(0, 0, 0, 0.05);
  }
  .box-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    line-height: 1;
    letter-spacing: 0.02em;
    margin-bottom: 16px;
    transition: color 0.2s;
  }
  .box-desc {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 300;
    line-height: 1.65;
    color: var(--fg-secondary);
    margin-bottom: 36px;
    transition: color 0.2s;
  }
  .box:hover .box-desc {
    color: rgba(0, 0, 0, 0.55);
  }
  .box-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid var(--border-default);
    padding-top: 16px;
    transition: border-color 0.2s;
  }
  .box:hover .box-cta {
    border-color: rgba(0, 0, 0, 0.15);
  }
  .box-cta-label {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--fg-secondary);
    transition: color 0.2s;
  }
  .box:hover .box-cta-label {
    color: #000;
  }
  .box-arrow {
    width: 28px;
    height: 28px;
    border: 1px solid var(--border-default);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    transition: all 0.2s;
  }
  .box:hover .box-arrow {
    border-color: #000;
    background: #000;
    color: #fff;
  }
</style>
