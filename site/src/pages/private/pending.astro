---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const user = Astro.locals.user;
---

<BaseLayout title="Pending Approval — Mathlacome">
  <Nav active="private" />

  <main class="auth-page">
    <div class="auth-header">
      <div class="page-label">02 / Private Access</div>
      <h1 class="page-title">Request<br />Received.</h1>
    </div>

    <p class="pending-copy">
      Your account ({user?.email}) is registered but hasn't been approved yet. This section is invite-only — I review
      requests myself, so it may take a little while. Check back later, or reach out if you were told to expect access.
    </p>

    <form method="POST" action="/api/auth/logout">
      <button type="submit" class="logout-btn">Log out</button>
    </form>
  </main>

  <Footer />
</BaseLayout>

<style>
  .auth-page {
    min-height: 100vh;
    padding: 140px 32px 96px;
    max-width: 480px;
    margin: 0 auto;
    width: 100%;
    display: flex;
    flex-direction: column;
  }
  .auth-header {
    margin-bottom: 32px;
  }
  .page-label {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fg-secondary);
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .page-label::before {
    content: '';
    display: inline-block;
    width: 5px;
    height: 5px;
    background: var(--fg-primary);
  }
  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 0.95;
    letter-spacing: 0.02em;
  }
  .pending-copy {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 300;
    line-height: 1.75;
    color: var(--fg-secondary);
    margin-bottom: 40px;
  }
  .logout-btn {
    align-self: flex-start;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--fg-secondary);
    background: none;
    border: 1px solid var(--border-default);
    padding: 13px 28px;
    cursor: pointer;
    transition: all 0.12s;
  }
  .logout-btn:hover {
    color: #000;
    background: #fff;
    border-color: #fff;
  }
</style>
